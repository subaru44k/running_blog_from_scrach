---
import Layout from '../../layouts/Layout.astro';
import RelatedGames from '../../components/games/RelatedGames.astro';
import catalogData from '../../lib/games/dressup-next-catalog.json';

const pageTitle = 'おしゃれゲーム ネクスト｜ミニゲーム';
const metaDescription = 'PNGレイヤー素材を重ねて、おひめさま風のコーデを作る新しいきせかえゲームです。';
---

<Layout
  pageTitle={pageTitle}
  metaDescription={metaDescription}
  noSidebar={true}
  pageHeading="おしゃれゲーム ネクスト"
  pageLead="かみかざり、ネックレス、トップス、ボトムス、くつをえらんで、チャットさんとコーデをくらべて遊べます。"
>
  <section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start">
  <article class="dn-shell" id="dressupNextGame">
    <div class="dn-topbar">
      <div>
        <p class="dn-kicker">DRESS UP GAME</p>
        <h2>おしゃれゲーム ネクスト</h2>
      </div>
      <div class="dn-actions">
        <button id="completeBtn" class="dn-btn dn-btn-primary" type="button">かんせい</button>
        <button id="restartBtn" class="dn-btn" type="button">もういちど</button>
      </div>
    </div>

    <div class="dn-status" aria-live="polite">
      <span>テーマ</span>
      <strong id="themeText">おでかけ</strong>
      <span>いま</span>
      <strong id="phaseText">コーデをつくろう</strong>
      <span>えらぶ</span>
      <strong id="slotText">かみかざり</strong>
    </div>

    <div class="dn-duel">
      <section class="dn-panel dn-player-panel">
        <div class="dn-panel-head">
          <strong>あなた</strong>
          <span id="playerHint">すきなところをえらんでね</span>
        </div>
        <div class="dn-avatar-wrap">
          <div class="dn-avatar" id="playerAvatar"></div>
          <div class="dn-hotspots" id="hotspots">
            <button class="dn-hotspot dn-hotspot-hair" data-slot="hairAccessory" type="button" aria-label="かみかざりをえらぶ"></button>
            <button class="dn-hotspot dn-hotspot-necklace" data-slot="necklace" type="button" aria-label="ネックレスをえらぶ"></button>
            <button class="dn-hotspot dn-hotspot-top" data-slot="top" type="button" aria-label="トップスをえらぶ"></button>
            <button class="dn-hotspot dn-hotspot-bottom" data-slot="bottom" type="button" aria-label="ボトムスをえらぶ"></button>
            <button class="dn-hotspot dn-hotspot-shoes" data-slot="shoes" type="button" aria-label="くつをえらぶ"></button>
          </div>
        </div>
      </section>

      <div class="dn-vs">VS</div>

      <section class="dn-panel dn-chat-panel" id="chatPanel">
        <div class="dn-panel-head">
          <strong>チャットさん</strong>
          <span id="chatHint">まだ ないしょ</span>
        </div>
        <div class="dn-avatar-wrap">
          <div class="dn-avatar" id="chatAvatar"></div>
          <div class="dn-thinking" id="chatThinking" hidden>
            <span></span>
            <strong id="chatThinkingText">えらんでいます</strong>
          </div>
        </div>
      </section>
    </div>

    <section class="dn-picker" id="picker">
      <div class="dn-picker-head">
        <div>
          <strong id="pickerTitle">かみかざり</strong>
          <span>カードの画像で、えらぶ前にどんなアイテムか見られます。</span>
        </div>
        <div class="dn-slot-tabs" id="slotTabs" aria-label="えらぶ場所"></div>
      </div>
      <div class="dn-options" id="optionList"></div>
      <div class="dn-page-controls" id="pageControls" aria-label="アイテムのページ選び"></div>
    </section>

    <section class="dn-vote" id="voteArea" hidden>
      <p>どっちがすき？</p>
      <div>
        <button class="dn-btn dn-btn-primary" data-pick="player" type="button">あなたのコーデ</button>
        <button class="dn-btn dn-btn-primary" data-pick="chat" type="button">チャットさんのコーデ</button>
      </div>
      <strong id="voteMessage"></strong>
    </section>

    <div class="dn-info-grid">
      <section class="dn-info">
        <h3>遊び方</h3>
        <ol>
          <li>モデルの部位、または部位ボタンをえらびます。</li>
          <li>カードのプレビューを見ながら、すきなアイテムをえらびます。</li>
          <li>「かんせい」を押すと、チャットさんもテーマに合わせてコーデを作ります。</li>
          <li>できあがったら、どちらのコーデがすきか選んで遊びます。</li>
        </ol>
      </section>

      <section class="dn-info">
        <h3>向いている場面</h3>
        <p>小さな子どもが、色や組み合わせをゆっくり選びたいときに向いています。勝ち負けよりも、できあがったコーデを見比べて話す遊びです。</p>
      </section>
    </div>
  </article>

  <RelatedGames currentHref="/games/dressup-next/" />
  </section>

  <style is:global>
    .dn-shell {
      display: grid;
      gap: 18px;
      color: #182234;
    }

    .dn-topbar,
    .dn-status,
    .dn-picker,
    .dn-vote,
    .dn-info,
    .dn-panel {
      border: 1px solid rgba(203, 213, 225, 0.85);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 18px 48px rgba(15, 23, 42, 0.07);
    }

    .dn-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 18px;
    }

    .dn-kicker {
      margin: 0 0 4px;
      color: #0f766e;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.12em;
    }

    .dn-topbar h2 {
      margin: 0;
      font-size: clamp(24px, 4vw, 36px);
      line-height: 1.15;
    }

    .dn-actions,
    .dn-vote div,
    .dn-slot-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .dn-btn,
    .dn-tab {
      border: 1px solid #cbd5e1;
      border-radius: 999px;
      background: #fff;
      color: #334155;
      cursor: pointer;
      font-weight: 800;
      min-height: 42px;
      padding: 0 16px;
    }

    .dn-btn-primary {
      border-color: #0f766e;
      background: #0f766e;
      color: #fff;
    }

    .dn-btn:disabled {
      cursor: default;
      opacity: 0.58;
    }

    .dn-tab {
      min-height: 34px;
      padding: 0 12px;
      font-size: 13px;
    }

    .dn-tab.is-active {
      border-color: #0f766e;
      background: #e6f4f1;
      color: #0f5f59;
    }

    .dn-status {
      display: grid;
      grid-template-columns: repeat(3, max-content 1fr);
      gap: 8px 12px;
      align-items: center;
      padding: 14px 16px;
    }

    .dn-status span,
    .dn-panel-head span,
    .dn-picker-head span,
    .dn-option span,
    .dn-info p,
    .dn-info li {
      color: #64748b;
      font-size: 13px;
      line-height: 1.7;
    }

    .dn-status strong {
      color: #0f766e;
    }

    .dn-duel {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 14px;
      align-items: center;
    }

    .dn-panel {
      padding: 14px;
    }

    .dn-chat-panel.is-thinking {
      border-color: rgba(15, 118, 110, 0.65);
      box-shadow: 0 18px 48px rgba(15, 118, 110, 0.13);
    }

    .dn-panel-head,
    .dn-picker-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .dn-picker-head strong {
      display: block;
      margin-bottom: 2px;
    }

    .dn-vs {
      color: #0f766e;
      font-size: 20px;
      font-weight: 900;
    }

    .dn-avatar-wrap {
      position: relative;
      width: min(100%, 380px);
      margin: 0 auto;
      aspect-ratio: 2 / 3;
    }

    .dn-avatar {
      position: absolute;
      inset: 0;
    }

    .dn-layer {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      pointer-events: none;
      user-select: none;
    }

    .dn-hotspots {
      position: absolute;
      inset: 0;
      transition: opacity 0.18s ease;
    }

    .dn-shell.is-locked .dn-hotspots {
      opacity: 0;
      pointer-events: none;
    }

    .dn-hotspot {
      position: absolute;
      border: 2px solid transparent;
      border-radius: 999px;
      background: rgba(15, 118, 110, 0.09);
      cursor: pointer;
    }

    .dn-hotspot:focus-visible,
    .dn-hotspot.is-active {
      border-color: #0f766e;
      outline: none;
    }

    .dn-hotspot-hair { left: 55%; top: 12%; width: 18%; height: 9%; }
    .dn-hotspot-necklace { left: 42%; top: 22%; width: 15%; height: 8%; }
    .dn-hotspot-top { left: 34%; top: 26.5%; width: 31%; height: 17%; }
    .dn-hotspot-bottom { left: 28%; top: 35%; width: 43%; height: 31%; }
    .dn-hotspot-shoes { left: 37%; top: 84%; width: 24%; height: 11%; }

    .dn-thinking {
      position: absolute;
      left: 50%;
      top: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 34px;
      transform: translateX(-50%);
      border: 1px solid rgba(15, 118, 110, 0.28);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.94);
      color: #0f5f59;
      padding: 0 12px;
      font-size: 13px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      white-space: nowrap;
    }

    .dn-thinking span {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: #0f766e;
      animation: dnPulse 0.9s ease-in-out infinite;
    }

    .dn-thinking[hidden] {
      display: none;
    }

    .dn-picker {
      padding: 14px;
    }

    .dn-shell.is-locked .dn-picker {
      display: none;
    }

    .dn-options {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(156px, 1fr));
      gap: 10px;
    }

    .dn-page-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 12px;
    }

    .dn-page-count {
      min-width: 64px;
      color: #0f766e;
      font-size: 14px;
      font-weight: 900;
      text-align: center;
    }

    .dn-option {
      display: grid;
      gap: 8px;
      grid-template-rows: 132px auto;
      border: 1px solid #dbe4ef;
      border-radius: 8px;
      background: #fff;
      cursor: pointer;
      min-height: 210px;
      padding: 10px;
      text-align: left;
    }

    .dn-option.is-selected {
      border-color: #0f766e;
      box-shadow: inset 0 0 0 2px rgba(15, 118, 110, 0.18);
    }

    .dn-option-preview {
      position: relative;
      display: grid;
      place-items: center;
      overflow: hidden;
      border: 1px solid #e6edf5;
      border-radius: 8px;
      background:
        linear-gradient(45deg, #f1f5f9 25%, transparent 25%) 0 0 / 18px 18px,
        linear-gradient(-45deg, #f1f5f9 25%, transparent 25%) 0 0 / 18px 18px,
        linear-gradient(45deg, transparent 75%, #f1f5f9 75%) 0 0 / 18px 18px,
        linear-gradient(-45deg, transparent 75%, #f1f5f9 75%) 0 0 / 18px 18px,
        #fff;
    }

    .dn-item-preview {
      width: calc(100% - 14px);
      height: calc(100% - 14px);
      object-fit: contain;
      pointer-events: none;
      user-select: none;
    }

    .dn-option-empty {
      display: grid;
      place-items: center;
      color: #94a3b8;
      font-size: 13px;
      font-weight: 800;
    }

    .dn-option strong,
    .dn-option span {
      display: block;
    }

    .dn-option span {
      margin-top: 3px;
    }

    .dn-vote,
    .dn-info {
      padding: 16px;
    }

    .dn-vote p {
      margin: 0 0 12px;
      font-size: 20px;
      font-weight: 900;
    }

    .dn-vote strong {
      display: block;
      margin-top: 12px;
      color: #0f766e;
    }

    .dn-info-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
      gap: 14px;
    }

    .dn-info h3 {
      margin: 0 0 8px;
      font-size: 18px;
    }

    .dn-info ol,
    .dn-info p {
      margin: 0;
    }

    .dn-info ol {
      padding-left: 1.25rem;
    }

    @keyframes dnPulse {
      0%, 100% { transform: scale(0.8); opacity: 0.55; }
      50% { transform: scale(1.1); opacity: 1; }
    }

    @media (max-width: 900px) {
      .dn-topbar,
      .dn-panel-head,
      .dn-picker-head {
        align-items: flex-start;
        flex-direction: column;
      }

      .dn-status {
        grid-template-columns: max-content 1fr;
      }

      .dn-duel,
      .dn-info-grid {
        grid-template-columns: 1fr;
      }

      .dn-vs {
        text-align: center;
      }

      .dn-shell.is-player .dn-chat-panel,
      .dn-shell.is-player .dn-vs {
        display: none;
      }

      .dn-avatar-wrap {
        max-width: 300px;
      }
    }

    @media (max-width: 520px) {
      .dn-options {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .dn-option {
        grid-template-rows: 112px auto;
        min-height: 194px;
      }

      .dn-btn,
      .dn-tab,
      .dn-page-controls .dn-btn {
        width: 100%;
      }

      .dn-page-controls {
        display: grid;
        grid-template-columns: 1fr max-content 1fr;
      }
    }
  </style>

  <script define:vars={{ catalogData }}>
    const ASSET_BASE = catalogData.assetBase;
    const slotOrder = catalogData.slots;
    const slotLabels = catalogData.slotLabels;
    const catalog = catalogData.catalog;
    const themes = catalogData.themes;
    const PAGE_SIZE = 8;
    const defaults = Object.fromEntries(slotOrder.map((slot) => [slot, 'none']));
    const state = {
      activeSlot: 'hairAccessory',
      chatActiveSlot: null,
      phase: 'player',
      theme: themes[Math.floor(Math.random() * themes.length)],
      player: { ...defaults },
      chat: { ...defaults },
      pageBySlot: Object.fromEntries(slotOrder.map((slot) => [slot, 0])),
    };

    const els = {
      shell: document.getElementById('dressupNextGame'),
      themeText: document.getElementById('themeText'),
      phaseText: document.getElementById('phaseText'),
      slotText: document.getElementById('slotText'),
      pickerTitle: document.getElementById('pickerTitle'),
      optionList: document.getElementById('optionList'),
      pageControls: document.getElementById('pageControls'),
      slotTabs: document.getElementById('slotTabs'),
      playerAvatar: document.getElementById('playerAvatar'),
      chatAvatar: document.getElementById('chatAvatar'),
      chatHint: document.getElementById('chatHint'),
      playerHint: document.getElementById('playerHint'),
      chatPanel: document.getElementById('chatPanel'),
      chatThinking: document.getElementById('chatThinking'),
      chatThinkingText: document.getElementById('chatThinkingText'),
      completeBtn: document.getElementById('completeBtn'),
      restartBtn: document.getElementById('restartBtn'),
      hotspots: document.getElementById('hotspots'),
      voteArea: document.getElementById('voteArea'),
      voteMessage: document.getElementById('voteMessage'),
    };

    const optionFor = (slot, id) => catalog[slot].find((item) => item.id === id) || catalog[slot][0];
    const imageTag = (src, alt, className = 'dn-layer') =>
      `<img class="${className}" src="${ASSET_BASE}${src}" alt="${alt}" loading="eager" decoding="async" />`;

    const outfitLayers = (outfit, className = 'dn-layer') => {
      const bottom = optionFor('bottom', outfit.bottom);
      const top = optionFor('top', outfit.top);
      const shoes = optionFor('shoes', outfit.shoes);
      const necklace = optionFor('necklace', outfit.necklace);
      const hair = optionFor('hairAccessory', outfit.hairAccessory);
      return [
        imageTag('model-base.png', 'ベースモデル', className),
        bottom.src ? imageTag(bottom.src, bottom.label, className) : '',
        top.src ? imageTag(top.src, top.label, className) : '',
        shoes.left ? imageTag(shoes.left, `${shoes.label} 左`, className) : '',
        shoes.right ? imageTag(shoes.right, `${shoes.label} 右`, className) : '',
        necklace.src ? imageTag(necklace.src, necklace.label, className) : '',
        hair.src ? imageTag(hair.src, hair.label, className) : '',
      ].join('');
    };

    const previewLayers = (slot, item) => {
      if (item.id === 'none') return '<div class="dn-option-empty">なし</div>';
      return item.preview
        ? `<img class="dn-item-preview" src="${ASSET_BASE}${item.preview}" alt="${item.label}" loading="eager" decoding="async" />`
        : '<div class="dn-option-empty">なし</div>';
    };

    function renderSlotTabs() {
      els.slotTabs.innerHTML = slotOrder
        .map((slot) => `<button class="dn-tab ${state.activeSlot === slot ? 'is-active' : ''}" data-slot-tab="${slot}" type="button">${slotLabels[slot]}</button>`)
        .join('');
    }

    function selectedPageForSlot(slot) {
      const index = Math.max(0, catalog[slot].findIndex((item) => item.id === state.player[slot]));
      return Math.floor(index / PAGE_SIZE);
    }

    function setActiveSlot(slot) {
      state.activeSlot = slot;
      state.pageBySlot[slot] = selectedPageForSlot(slot);
    }

    function renderOptions() {
      els.pickerTitle.textContent = slotLabels[state.activeSlot];
      els.slotText.textContent = slotLabels[state.activeSlot];
      const items = catalog[state.activeSlot];
      const pageCount = Math.max(1, Math.ceil(items.length / PAGE_SIZE));
      const page = Math.max(0, Math.min(state.pageBySlot[state.activeSlot] || 0, pageCount - 1));
      state.pageBySlot[state.activeSlot] = page;
      const pageItems = items.slice(page * PAGE_SIZE, page * PAGE_SIZE + PAGE_SIZE);
      els.optionList.innerHTML = pageItems
        .map((item) => {
          const selected = state.player[state.activeSlot] === item.id;
          return `<button class="dn-option ${selected ? 'is-selected' : ''}" data-option="${item.id}" type="button">
            <div class="dn-option-preview">${previewLayers(state.activeSlot, item)}</div>
            <span><strong>${item.label}</strong><span>${item.note}</span></span>
          </button>`;
        })
        .join('');
      els.pageControls.innerHTML = pageCount > 1
        ? `<button class="dn-btn" data-page-action="prev" type="button" ${page === 0 ? 'disabled' : ''}>まえ</button>
           <span class="dn-page-count">${page + 1} / ${pageCount}</span>
           <button class="dn-btn" data-page-action="next" type="button" ${page >= pageCount - 1 ? 'disabled' : ''}>つぎ</button>`
        : '';
      renderSlotTabs();
    }

    function renderAll() {
      els.themeText.textContent = state.theme;
      els.phaseText.textContent =
        state.phase === 'player' ? 'コーデをつくろう' : state.phase === 'chat' ? 'チャットさんがえらぶ' : 'どっちがすき？';
      els.playerAvatar.innerHTML = outfitLayers(state.player);
      els.chatAvatar.innerHTML = outfitLayers(state.chat);
      els.shell.classList.toggle('is-locked', state.phase !== 'player');
      els.shell.classList.toggle('is-player', state.phase === 'player');
      els.shell.classList.toggle('is-chat', state.phase === 'chat');
      els.shell.classList.toggle('is-vote', state.phase === 'vote');
      const isChatThinking = state.phase === 'chat' && Boolean(state.chatActiveSlot);
      const chatThinkingText = isChatThinking ? `${slotLabels[state.chatActiveSlot]}を えらんでいます` : '';
      els.chatPanel.classList.toggle('is-thinking', isChatThinking);
      els.chatThinking.hidden = !isChatThinking;
      els.chatThinkingText.textContent = chatThinkingText || 'えらんでいます';
      els.chatHint.textContent =
        state.phase === 'player' ? 'まだ ないしょ' : state.phase === 'vote' ? 'できあがり' : chatThinkingText;
      document.querySelectorAll('.dn-hotspot').forEach((button) => {
        button.classList.toggle('is-active', button.dataset.slot === state.activeSlot && state.phase === 'player');
      });
      renderOptions();
    }

    function pickChatOption(slot) {
      const items = catalog[slot].filter((item) => item.id !== 'none');
      return items[Math.floor(Math.random() * items.length)]?.id || 'none';
    }

    function sleep(ms) {
      return new Promise((resolve) => setTimeout(resolve, ms));
    }

    async function runChat() {
      state.phase = 'chat';
      state.chat = { ...defaults };
      state.chatActiveSlot = null;
      els.completeBtn.disabled = true;
      els.voteArea.hidden = true;
      els.playerHint.textContent = 'できあがり';
      renderAll();
      for (const slot of slotOrder) {
        state.chatActiveSlot = slot;
        renderAll();
        await sleep(720);
        state.chat[slot] = pickChatOption(slot);
        renderAll();
        await sleep(180);
      }
      state.chatActiveSlot = null;
      state.phase = 'vote';
      els.voteArea.hidden = false;
      els.completeBtn.disabled = false;
      renderAll();
    }

    els.hotspots.addEventListener('click', (event) => {
      const button = event.target.closest('[data-slot]');
      if (!button || state.phase !== 'player') return;
      setActiveSlot(button.dataset.slot);
      renderAll();
    });

    els.slotTabs.addEventListener('click', (event) => {
      const button = event.target.closest('[data-slot-tab]');
      if (!button || state.phase !== 'player') return;
      setActiveSlot(button.dataset.slotTab);
      renderAll();
    });

    els.optionList.addEventListener('click', (event) => {
      const button = event.target.closest('[data-option]');
      if (!button || state.phase !== 'player') return;
      state.player[state.activeSlot] = button.dataset.option;
      renderAll();
    });

    els.pageControls.addEventListener('click', (event) => {
      const button = event.target.closest('[data-page-action]');
      if (!button || state.phase !== 'player') return;
      const pageCount = Math.max(1, Math.ceil(catalog[state.activeSlot].length / PAGE_SIZE));
      const direction = button.dataset.pageAction === 'next' ? 1 : -1;
      state.pageBySlot[state.activeSlot] = Math.max(0, Math.min((state.pageBySlot[state.activeSlot] || 0) + direction, pageCount - 1));
      renderAll();
    });

    els.completeBtn.addEventListener('click', () => {
      if (state.phase === 'player') runChat();
    });

    els.restartBtn.addEventListener('click', () => {
      state.phase = 'player';
      state.theme = themes[Math.floor(Math.random() * themes.length)];
      state.activeSlot = 'hairAccessory';
      state.chatActiveSlot = null;
      state.player = { ...defaults };
      state.chat = { ...defaults };
      state.pageBySlot = Object.fromEntries(slotOrder.map((slot) => [slot, 0]));
      els.voteArea.hidden = true;
      els.voteMessage.textContent = '';
      els.playerHint.textContent = 'すきなところをえらんでね';
      els.completeBtn.disabled = false;
      renderAll();
    });

    els.voteArea.addEventListener('click', (event) => {
      const button = event.target.closest('[data-pick]');
      if (!button) return;
      els.voteMessage.textContent = button.dataset.pick === 'player' ? 'あなたのコーデ、すてきだね。' : 'チャットさんのコーデも いいかんじ。';
    });

    renderAll();
  </script>
</Layout>
