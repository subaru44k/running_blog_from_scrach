    function randomTheme() {
      const candidates = THEMES.filter((item) => item.id !== previousThemeId);
      return candidates[Math.floor(Math.random() * candidates.length)] || THEMES[0];
    }

    function getOption(slot, id) {
      return CATALOG[slot].find((item) => item.id === id) || CATALOG[slot][0];
    }

    function pickWeighted(slot, themeId) {
      const options = CATALOG[slot];
      const weighted = options.map((item) => ({
        item,
        weight: item.weights?.[themeId] ?? 1,
      }));
      const total = weighted.reduce((sum, entry) => sum + entry.weight, 0);
      let threshold = Math.random() * total;
      for (const entry of weighted) {
        threshold -= entry.weight;
        if (threshold <= 0) return entry.item.id;
      }
      return weighted[weighted.length - 1].item.id;
    }

