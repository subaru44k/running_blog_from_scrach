      if (variant === 'pants') {
        return `<path d="M66 144h20l-2 14-6 42H66l-4-42 4-14Z" fill="${color}"></path><path d="M94 144h20l4 14-4 42H102l-6-42-2-14Z" fill="${color}"></path><path d="M76 150h28" stroke="${accent}" stroke-width="3" stroke-linecap="round"></path>`;
