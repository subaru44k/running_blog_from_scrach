    function renderSlotBar() {
      const disabled = phase !== 'editing';
      slotBarEl.innerHTML = SLOT_ORDER.map((slot) => {
        const option = getOption(slot, playerOutfit[slot]);
        const isActive = slot === activeSlot;
        const totalPages = Math.ceil(CATALOG[slot].length / OPTIONS_PER_PAGE);
        const page = Math.max(0, Math.min(slotPages[slot] ?? 0, totalPages - 1));
        const start = page * OPTIONS_PER_PAGE;
        const visibleChoices = CATALOG[slot].slice(start, start + OPTIONS_PER_PAGE);
        return `
          <section class="du-slot-card ${isActive ? 'is-active' : ''} ${disabled ? 'is-disabled' : ''}">
            <button class="du-slot-head" data-slot-select="${slot}" type="button" ${disabled ? 'disabled' : ''}>
              <span class="du-slot-copy">
                <span class="du-slot-name">${escapeHtml(SLOT_LABELS[slot])}</span>
                <span class="du-slot-value">${escapeHtml(option.label)}</span>
                <span class="du-slot-help">タップして えらぶ</span>
              </span>
              <span class="du-slot-thumb" aria-hidden="true">${renderPreview(option.preview)}</span>
            </button>
            <div class="du-slot-options" ${isActive ? '' : 'hidden'}>
              <div class="du-slot-options-head">
                <div>
                  <p class="du-slot-options-title">${escapeHtml(SLOT_LABELS[slot])}を えらぼう</p>
                  <span class="du-slot-options-tip">${disabled ? 'いまは まっててね' : 'えらぶと すぐに きせかわるよ'}</span>
                </div>
                <div class="du-slot-pager">
                  <button class="du-slot-page-btn" data-slot-page="${slot}" data-slot-page-delta="-1" type="button" ${disabled || page === 0 ? 'disabled' : ''}>まえ</button>
                  <span class="du-slot-page-indicator">${page + 1} / ${totalPages}</span>
                  <button class="du-slot-page-btn" data-slot-page="${slot}" data-slot-page-delta="1" type="button" ${disabled || page >= totalPages - 1 ? 'disabled' : ''}>つぎ</button>
                </div>
              </div>
              <div class="du-options">
                ${visibleChoices.map((choice) => `
                  <button class="du-option ${playerOutfit[slot] === choice.id ? 'is-selected' : ''}" data-slot-option="${slot}" data-option-id="${choice.id}" type="button" ${disabled ? 'disabled' : ''}>
                    <span class="du-option-preview">${renderPreview(choice.preview)}</span>
                    <span class="du-option-label">${escapeHtml(choice.label)}</span>
                    <span class="du-option-note">${escapeHtml(choice.note)}</span>
                  </button>
                `).join('')}
              </div>
            </div>
          </section>
        `;
      }).join('');
    }

    function updateStatus(text, kind = '') {
      statusEl.textContent = text;
      statusEl.classList.toggle('du-status-thinking', kind === 'thinking');
      statusEl.classList.toggle('du-status-picked', kind === 'picked');
    }

    function updatePhaseText() {
      if (phase === 'editing') phaseTextEl.textContent = 'コーデをつくろう';
      else if (phase === 'chat-thinking') phaseTextEl.textContent = 'チャットさん えらびちゅう';
      else if (phase === 'voting') phaseTextEl.textContent = 'どっちがすき？';
      else phaseTextEl.textContent = 'えらべたよ';
    }

    function updateGuides() {
      if (phase === 'editing') {
        stageTextEl.textContent = 'あなたのコーデをつくってね';
        guideTextEl.textContent = 'したのカードか マネキンを タップして えらべます';
      } else if (phase === 'chat-thinking') {
        stageTextEl.textContent = 'チャットさんが コーデをかんがえてるよ';
        guideTextEl.textContent = '1つずつ えらぶから まっててね';
      } else if (phase === 'voting') {
        stageTextEl.textContent = 'どっちのコーデがすき？';
        guideTextEl.textContent = 'すきな ほうを えらんでね';
      } else {
        stageTextEl.textContent = 'すきな コーデを えらべたね';
        guideTextEl.textContent = 'もういちど で あたらしい テーマにいけるよ';
      }
    }

    function renderVoteArea() {
      voteAreaEl.hidden = phase !== 'voting' && phase !== 'picked';
      voteMessageEl.textContent = phase === 'picked'
        ? favorite === 'player'
          ? 'あなたの コーデ すてきだね！'
          : 'チャットさんの コーデ すてきだね！'
        : '';
    }

    function renderCards() {
      playerAvatarEl.innerHTML = renderAvatar(playerOutfit);
      chatAvatarEl.innerHTML = renderAvatar(chatOutfit);
      playerHotspotsEl.hidden = phase !== 'editing';
      playerHotspotsEl.querySelectorAll('.du-hotspot-active').forEach((node) => node.remove());
      if (phase === 'editing') {
        const activeButton = playerHotspotsEl.querySelector(`[data-slot="${activeSlot}"]`);
        if (activeButton) {
          const ring = document.createElement('span');
          ring.className = `du-hotspot-active du-hotspot-${activeSlot === 'hairAccessory' ? 'hair' : activeSlot}`;
          playerHotspotsEl.appendChild(ring);
        }
      }
      slotTextEl.textContent = phase === 'chat-thinking'
        ? SLOT_LABELS[chatStatusSlot]
        : phase === 'editing'
          ? SLOT_LABELS[activeSlot]
          : 'えらびおわり';

      playerCardEl.classList.toggle('is-pickable', phase === 'voting');
      chatCardEl.classList.toggle('is-pickable', phase === 'voting');
      playerCardEl.classList.toggle('is-picked', favorite === 'player');
      chatCardEl.classList.toggle('is-picked', favorite === 'chat');
      chatCardEl.classList.toggle('is-revealing', revealPulse);
    }

    function renderThinkingOverlay() {
      const active = phase === 'chat-thinking';
      thinkingOverlayEl.hidden = !active;
      thinkingOverlayEl.classList.toggle('active', active);
      thinkingOverlayEl.setAttribute('aria-hidden', active ? 'false' : 'true');
      thinkingTitleEl.textContent = active ? 'チャットさんが かんがえちゅう' : 'チャットさんが かんがえちゅう';
      thinkingSlotEl.innerHTML = active
        ? `${SLOT_LABELS[chatStatusSlot]}を えらんでるよ<span class="dots"></span>`
        : '';
      thinkingCountEl.textContent = active ? `${chatStepIndex + 1} / ${SLOT_ORDER.length}` : '';
      thinkingStepsEl.innerHTML = SLOT_ORDER.map((slot, index) => {
        const klass = index < chatStepIndex ? 'done' : index === chatStepIndex ? 'active' : '';
        return `<span class="du-thinking-step ${klass}" title="${escapeHtml(SLOT_LABELS[slot])}"></span>`;
      }).join('');
    }

    function renderButtons() {
      completeBtn.disabled = phase !== 'editing';
      restartBtn.disabled = phase === 'chat-thinking';
    }

    function render() {
      themeTextEl.textContent = theme.label;
      updatePhaseText();
      updateGuides();
      renderCards();
      renderSlotBar();
      renderButtons();
      renderVoteArea();
      renderThinkingOverlay();
    }

    function chooseSlot(slot) {
      if (phase !== 'editing') return;
      activeSlot = slot;
      render();
    }

    function selectOption(slot, id) {
      if (phase !== 'editing') return;
      activeSlot = slot;
      playerOutfit = { ...playerOutfit, [slot]: id };
      updateStatus(`${SLOT_LABELS[slot]} を ${getOption(slot, id).label} にしたよ`);
      render();
    }

    function changeSlotPage(slot, delta) {
      if (phase !== 'editing') return;
      const totalPages = Math.ceil(CATALOG[slot].length / OPTIONS_PER_PAGE);
      const current = slotPages[slot] ?? 0;
      const next = Math.max(0, Math.min(current + delta, totalPages - 1));
      if (next === current) return;
      slotPages = { ...slotPages, [slot]: next };
      activeSlot = slot;
      render();
    }

    function pulseChatCard() {
      revealPulse = false;
      requestAnimationFrame(() => {
        revealPulse = true;
        renderCards();
        window.setTimeout(() => {
          revealPulse = false;
          renderCards();
        }, 360);
      });
    }

    function sleep(ms) {
      return new Promise((resolve) => window.setTimeout(resolve, ms));
    }

    async function runChatStyling() {
      const runId = ++thinkingRunId;
      phase = 'chat-thinking';
      favorite = '';
      chatStepIndex = 0;
      voteMessageEl.textContent = '';
      render();

      for (const [index, slot] of SLOT_ORDER.entries()) {
        if (runId !== thinkingRunId) return;
        chatStepIndex = index;
        chatStatusSlot = slot;
        updateStatus(`チャットさんが ${SLOT_LABELS[slot]} を えらんでるよ`, 'thinking');
        render();
        await sleep(1400);
        if (runId !== thinkingRunId) return;
        chatOutfit = { ...chatOutfit, [slot]: pickWeighted(slot, theme.id) };
        pulseChatCard();
        render();
        await sleep(600);
      }

      if (runId !== thinkingRunId) return;
      phase = 'voting';
      chatStatusSlot = '';
      chatStepIndex = 0;
      updateStatus('どっちの コーデが すきかな？');
      render();
    }

    function pickFavorite(which) {
      if (phase !== 'voting') return;
      favorite = which;
      phase = 'picked';
      updateStatus(which === 'player' ? 'あなたの コーデを えらんだね' : 'チャットさんの コーデを えらんだね', 'picked');
      render();
    }

    function startRound() {
      thinkingRunId += 1;
      previousThemeId = theme.id;
      theme = randomTheme();
      activeSlot = SLOT_ORDER[0];
      playerOutfit = createEmptyOutfit();
      chatOutfit = createEmptyOutfit();
      phase = 'editing';
      favorite = '';
      chatStatusSlot = '';
      chatStepIndex = 0;
      revealPulse = false;
      slotPages = createSlotPages();
      updateStatus('テーマにあうコーデをつくってね');
      render();
    }

    function buildEventHandlers() {
      slotBarEl.addEventListener('click', (event) => {
        const optionButton = event.target.closest('[data-slot-option][data-option-id]');
        if (optionButton) {
          selectOption(optionButton.dataset.slotOption, optionButton.dataset.optionId);
          return;
        }
        const pagerButton = event.target.closest('[data-slot-page][data-slot-page-delta]');
        if (pagerButton) {
          changeSlotPage(pagerButton.dataset.slotPage, Number(pagerButton.dataset.slotPageDelta || '0'));
          return;
        }
        const button = event.target.closest('[data-slot-select]');
        if (!button) return;
        chooseSlot(button.dataset.slotSelect);
      });

      playerHotspotsEl.addEventListener('click', (event) => {
        const button = event.target.closest('[data-slot]');
        if (!button) return;
        chooseSlot(button.dataset.slot);
      });

      completeBtn.addEventListener('click', () => {
        if (phase !== 'editing') return;
        runChatStyling();
      });

      restartBtn.addEventListener('click', () => {
        startRound();
      });

      voteAreaEl.addEventListener('click', (event) => {
        const button = event.target.closest('[data-pick]');
        if (!button) return;
        pickFavorite(button.dataset.pick);
      });

      playerCardEl.addEventListener('click', () => {
        if (phase === 'voting') pickFavorite('player');
      });

      chatCardEl.addEventListener('click', () => {
        if (phase === 'voting') pickFavorite('chat');
      });
    }

    buildEventHandlers();
    startRound();
  </script>
</Layout>
