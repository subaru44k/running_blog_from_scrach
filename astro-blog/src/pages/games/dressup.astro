---
import Layout from '../../layouts/Layout.astro';

const pageTitle = 'おしゃれゲーム｜ミニゲーム';
const metaDescription = 'テーマに合わせてコーデを作る、子ども向けのおしゃれゲームです。チャットさんのコーデづくりを見る演出つきで遊べます。';
---

<Layout
  pageTitle={pageTitle}
  metaDescription={metaDescription}
  noSidebar={true}
  pageHeading="おしゃれゲーム"
  pageLead="テーマに合わせて女の子のコーデを作るゲームです。あなたが着せ替えたあと、チャットさんも1つずつ選んでおしゃれ対決をします。"
>
  <section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start">
    <article class="card p-5 md:p-6">
      <div class="du-shell">
        <div class="du-top">
          <div>
            <p class="du-kicker">MINI GAME</p>
            <h2 class="du-title">おしゃれゲーム</h2>
          </div>
        </div>

        <div class="du-status" id="status">テーマにあうコーデをつくってね</div>

        <div class="du-meta">
          <div class="du-chip">
            <span class="du-chip-label">テーマ</span>
            <strong id="themeText">おでかけ</strong>
          </div>
          <div class="du-chip">
            <span class="du-chip-label">いま</span>
            <strong id="phaseText">コーデをつくろう</strong>
          </div>
          <div class="du-chip">
            <span class="du-chip-label">えらぶぶぶん</span>
            <strong id="slotText">かみかざり</strong>
          </div>
        </div>

        <div class="du-actions">
          <button class="du-btn du-btn-primary" id="completeBtn" type="button">かんせい</button>
          <button class="du-btn" id="restartBtn" type="button">もういちど</button>
        </div>

        <div class="du-stage">
          <div class="du-stage-head">
            <strong id="stageText">あなたのコーデをつくってね</strong>
            <span id="guideText">マネキンのぶぶんをタップすると えらべます</span>
          </div>

          <div class="du-duel">
            <section class="du-card du-card-player" id="playerCard">
              <p class="du-card-label">あなた</p>
              <div class="du-avatar-wrap">
                <div class="du-avatar" id="playerAvatar"></div>
                <div class="du-hotspots" id="playerHotspots">
                  <button class="du-hotspot du-hotspot-hair" data-slot="hairAccessory" type="button" aria-label="かみかざり を えらぶ"></button>
                  <button class="du-hotspot du-hotspot-necklace" data-slot="necklace" type="button" aria-label="ネックレス を えらぶ"></button>
                  <button class="du-hotspot du-hotspot-top" data-slot="top" type="button" aria-label="トップス を えらぶ"></button>
                  <button class="du-hotspot du-hotspot-bottom" data-slot="bottom" type="button" aria-label="ボトムス を えらぶ"></button>
                  <button class="du-hotspot du-hotspot-shoes" data-slot="shoes" type="button" aria-label="くつ を えらぶ"></button>
                </div>
              </div>
            </section>

            <div class="du-vs" id="vsText">VS</div>

            <section class="du-card du-card-chat" id="chatCard">
              <p class="du-card-label">チャットさん</p>
              <div class="du-avatar-wrap">
                <div class="du-avatar" id="chatAvatar"></div>
              </div>
            </section>
          </div>

          <div class="du-vote" id="voteArea" hidden>
            <p class="du-vote-title">どっちがすき？</p>
            <div class="du-vote-buttons">
              <button class="du-vote-btn" data-pick="player" type="button">あなたのコーデ</button>
              <button class="du-vote-btn" data-pick="chat" type="button">チャットさんのコーデ</button>
            </div>
            <p class="du-vote-message" id="voteMessage"></p>
          </div>

          <div class="du-thinking" id="thinkingOverlay" aria-hidden="true" hidden>
            <div class="du-thinking-panel">
              <p class="du-thinking-kicker">CHAT SAN</p>
              <strong class="du-thinking-title" id="thinkingTitle">チャットさんが かんがえちゅう</strong>
              <p class="du-thinking-slot" id="thinkingSlot">かみかざりを えらんでるよ<span class="dots"></span></p>
              <div class="du-thinking-progress">
                <span class="du-thinking-count" id="thinkingCount">1 / 5</span>
                <div class="du-thinking-steps" id="thinkingSteps" aria-hidden="true"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="du-slotbar" id="slotBar"></div>

        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <div class="rounded-2xl border border-slate-200/80 bg-white/70 p-4 dark:border-slate-700/80 dark:bg-slate-900/60">
            <h3 class="mt-0 text-base font-semibold">遊び方</h3>
            <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">マネキンのぶぶんをタップして、アイテムをえらびます。かんせいしたらチャットさんも1つずつえらぶので、さいごにどっちのコーデがすきかをえらびます。</p>
          </div>
          <div class="rounded-2xl border border-slate-200/80 bg-white/70 p-4 dark:border-slate-700/80 dark:bg-slate-900/60">
            <h3 class="mt-0 text-base font-semibold">向いている場面</h3>
            <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">おしゃれや色の組み合わせを楽しみたいときに向いています。遊びながら「どれがすき？」と話しやすい、やさしい対戦ゲームです。</p>
          </div>
        </div>
      </div>
    </article>

    <aside class="panel-muted p-5">
      <h2 class="text-lg font-semibold mt-0">ほかのゲーム</h2>
      <div class="mt-4 flex flex-col gap-3 text-sm">
        <a href="/games/janken/" class="rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 no-underline transition hover:bg-white dark:border-slate-700/80 dark:bg-slate-900/80 dark:hover:bg-slate-900">じゃんけんゲーム</a>
        <a href="/games/clock/" class="rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 no-underline transition hover:bg-white dark:border-slate-700/80 dark:bg-slate-900/80 dark:hover:bg-slate-900">とけいゲーム</a>
        <a href="/games/snake/" class="rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 no-underline transition hover:bg-white dark:border-slate-700/80 dark:bg-slate-900/80 dark:hover:bg-slate-900">スネークゲーム</a>
        <a href="/games/maze/" class="rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 no-underline transition hover:bg-white dark:border-slate-700/80 dark:bg-slate-900/80 dark:hover:bg-slate-900">めいろゲーム</a>
        <a href="/games/tic-tac-toe/" class="rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 no-underline transition hover:bg-white dark:border-slate-700/80 dark:bg-slate-900/80 dark:hover:bg-slate-900">まるばつゲーム</a>
        <a href="/games/reversi/" class="rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 no-underline transition hover:bg-white dark:border-slate-700/80 dark:bg-slate-900/80 dark:hover:bg-slate-900">リバーシ</a>
        <span class="rounded-2xl border border-slate-900/15 bg-slate-900 px-4 py-3 font-semibold text-white dark:border-white/15 dark:bg-white dark:text-slate-950">おしゃれゲーム</span>
        <a href="/draw/" class="rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 no-underline transition hover:bg-white dark:border-slate-700/80 dark:bg-slate-900/80 dark:hover:bg-slate-900">お絵かきゲーム</a>
      </div>
    </aside>
  </section>

  <style is:global>
    .du-shell { color: rgb(15 23 42); }
    .du-top { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:1rem; }
    .du-kicker { margin:0; font-size:.72rem; letter-spacing:.24em; font-weight:700; color:rgb(100 116 139); }
    .du-title { margin:.35rem 0 0; font-size:1.6rem; }
    .du-status {
      margin-bottom:1rem;
      font-weight:700;
      padding:.95rem 1rem;
      border-radius:1rem;
      background:linear-gradient(135deg, rgba(254,240,245,.92), rgba(255,248,220,.84));
      border:1px solid rgba(244,114,182,.18);
      transition:background-color .2s ease,border-color .2s ease,color .2s ease;
    }
    .du-status.du-status-thinking {
      background:linear-gradient(135deg, rgba(191,219,254,.92), rgba(224,231,255,.84));
      border-color:rgba(59,130,246,.22);
      color:rgb(30 64 175);
    }
    .du-status.du-status-picked {
      background:linear-gradient(135deg, rgba(220,252,231,.92), rgba(254,249,195,.84));
      border-color:rgba(34,197,94,.2);
      color:rgb(22 101 52);
    }
    .du-meta { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:.75rem; margin-bottom:1rem; }
    .du-chip { display:grid; gap:.2rem; border:1px solid rgba(148,163,184,.35); border-radius:1rem; background:rgba(255,255,255,.85); padding:.8rem .9rem; }
    .du-chip-label { font-size:.76rem; font-weight:700; color:rgb(100 116 139); letter-spacing:.08em; }
    .du-chip strong { font-size:1rem; }
    .du-actions { display:flex; flex-wrap:wrap; gap:.75rem; margin-bottom:1rem; }
    .du-btn {
      border:1px solid rgba(51,65,85,.22);
      border-radius:1rem;
      background:rgba(255,255,255,.92);
      color:rgb(15 23 42);
      font-weight:700;
      padding:.8rem 1rem;
      cursor:pointer;
      transition:transform .15s ease, background-color .15s ease, opacity .15s ease;
    }
    .du-btn:hover { transform:translateY(-1px); background:white; }
    .du-btn:disabled { opacity:.55; cursor:default; transform:none; }
    .du-btn-primary { background:rgb(15 23 42); color:white; border-color:rgb(15 23 42); }
    .du-btn-primary:hover { background:rgb(30 41 59); }
    .du-stage {
      position:relative;
      border:1px solid rgba(244,114,182,.18);
      border-radius:1.35rem;
      padding:1rem;
      background:
        radial-gradient(circle at top, rgba(255,255,255,.72), transparent 42%),
        linear-gradient(180deg, rgba(255,251,235,.98), rgba(255,241,242,.96));
      box-shadow: inset 0 1px 0 rgba(255,255,255,.78);
      overflow:hidden;
    }
    .du-stage-head { display:grid; gap:.2rem; justify-items:center; text-align:center; margin-bottom:1rem; }
    .du-stage-head strong { font-size:1.05rem; }
    .du-stage-head span { color:rgb(71 85 105); font-size:.92rem; }
    .du-duel { display:grid; grid-template-columns:minmax(0,1fr) auto minmax(0,1fr); gap:1rem; align-items:start; }
    .du-vs {
      align-self:center;
      justify-self:center;
      border-radius:999px;
      padding:.5rem .9rem;
      font-weight:800;
      letter-spacing:.14em;
      color:rgb(244 114 182);
      background:rgba(255,255,255,.88);
      border:1px solid rgba(244,114,182,.22);
    }
    .du-card {
      border:1px solid rgba(148,163,184,.26);
      border-radius:1.2rem;
      background:
        radial-gradient(circle at top, rgba(255,255,255,.98), rgba(255,249,251,.92) 58%, rgba(255,240,245,.9));
      padding:.9rem;
      transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease, background-color .18s ease;
    }
    .du-card-label { margin:0 0 .55rem; text-align:center; font-weight:800; }
    .du-card.is-pickable { cursor:pointer; }
    .du-card.is-picked {
      border-color:rgba(244,114,182,.48);
      box-shadow:0 0 0 3px rgba(244,114,182,.18);
      background:linear-gradient(180deg, rgba(255,241,242,.98), rgba(255,255,255,.96));
    }
    .du-card.is-revealing .du-avatar-frame { animation:duPop .34s ease-out; }
    .du-avatar-wrap { position:relative; width:min(100%, 17rem); margin:0 auto; }
    .du-avatar { width:100%; aspect-ratio: 0.72; }
    .du-avatar-frame { width:100%; height:100%; display:block; }
    .du-hotspots {
      position:absolute;
      inset:0;
      pointer-events:none;
    }
    .du-hotspot {
      position:absolute;
      pointer-events:auto;
      border:none;
      background:transparent;
      border-radius:999px;
      cursor:pointer;
      outline-offset:2px;
    }
    .du-hotspot:hover,
    .du-hotspot:focus-visible { box-shadow:0 0 0 3px rgba(244,114,182,.28), 0 0 16px rgba(251,207,232,.75); }
    .du-hotspot-active {
      position:absolute;
      pointer-events:none;
      border:2px dashed rgba(244,114,182,.72);
      border-radius:999px;
      box-shadow:0 0 0 6px rgba(253,242,248,.72), 0 0 20px rgba(244,114,182,.22);
      animation: duRing 1.2s ease-in-out infinite;
    }
    .du-hotspot-hair { left:28%; top:6%; width:44%; height:20%; }
    .du-hotspot-necklace { left:34%; top:28%; width:32%; height:13%; }
    .du-hotspot-top { left:22%; top:35%; width:56%; height:24%; }
    .du-hotspot-bottom { left:23%; top:57%; width:54%; height:20%; }
    .du-hotspot-shoes { left:24%; top:79%; width:52%; height:14%; }
    .du-slotbar {
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:.8rem;
      margin-top:1rem;
    }
    .du-slot-card {
      border:1px solid rgba(148,163,184,.28);
      border-radius:1.15rem;
      background:linear-gradient(180deg, rgba(255,255,255,.97), rgba(255,247,250,.92));
      box-shadow:0 8px 22px rgba(244,114,182,.06);
      overflow:hidden;
      transition:border-color .18s ease, box-shadow .18s ease, background-color .18s ease;
    }
    .du-slot-card.is-active {
      border-color:rgba(244,114,182,.42);
      background:linear-gradient(180deg, rgba(255,241,242,.98), rgba(255,251,235,.96));
      box-shadow:0 0 0 3px rgba(244,114,182,.12), 0 16px 28px rgba(251,113,133,.1);
    }
    .du-slot-card.is-disabled { opacity:.62; }
    .du-slot-head {
      width:100%;
      border:none;
      background:transparent;
      padding:.95rem .95rem .85rem;
      text-align:left;
      cursor:pointer;
      display:grid;
      grid-template-columns:minmax(0,1fr) 3.5rem;
      gap:.7rem;
      align-items:center;
    }
    .du-slot-head:disabled { cursor:default; }
    .du-slot-copy { display:grid; gap:.14rem; }
    .du-slot-name { display:block; font-size:.76rem; font-weight:800; color:rgb(71 85 105); letter-spacing:.08em; }
    .du-slot-value { display:block; font-size:1rem; font-weight:800; color:rgb(15 23 42); }
    .du-slot-help { display:block; font-size:.78rem; color:rgb(100 116 139); line-height:1.4; }
    .du-slot-thumb {
      width:3.5rem;
      height:3.5rem;
      border-radius:1rem;
      border:1px solid rgba(244,114,182,.14);
      background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(255,241,242,.94));
      display:grid;
      place-items:center;
      padding:.2rem;
      box-sizing:border-box;
    }
    .du-slot-thumb svg { width:100%; height:100%; display:block; }
    .du-slot-options {
      border-top:1px dashed rgba(244,114,182,.18);
      padding:.85rem .95rem .95rem;
      display:grid;
      gap:.62rem;
      animation:duExpand .2s ease-out;
    }
    .du-slot-options[hidden] { display:none; }
    .du-slot-options-head {
      display:flex;
      justify-content:space-between;
      gap:.75rem;
      align-items:flex-end;
    }
    .du-slot-options-title {
      margin:0;
      font-size:1rem;
      font-weight:800;
      color:rgb(157 23 77);
    }
    .du-slot-options-tip { font-size:.8rem; font-weight:700; color:rgb(100 116 139); }
    .du-slot-pager {
      display:flex;
      align-items:center;
      gap:.4rem;
      flex-wrap:wrap;
    }
    .du-slot-page-btn {
      border:1px solid rgba(244,114,182,.24);
      border-radius:999px;
      background:rgba(255,255,255,.96);
      color:rgb(157 23 77);
      font-weight:800;
      font-size:.8rem;
      padding:.42rem .72rem;
      cursor:pointer;
      transition:transform .15s ease, background-color .15s ease, opacity .15s ease;
    }
    .du-slot-page-btn:hover { transform:translateY(-1px); background:white; }
    .du-slot-page-btn:disabled { opacity:.45; cursor:default; transform:none; }
    .du-slot-page-indicator {
      font-size:.78rem;
      font-weight:800;
      color:rgb(100 116 139);
      min-width:2.9rem;
      text-align:center;
    }
    .du-options { display:grid; grid-template-columns:repeat(auto-fit,minmax(8.2rem,1fr)); gap:.62rem; }
    .du-option {
      border:1px solid rgba(148,163,184,.28);
      border-radius:1rem;
      background:rgba(255,255,255,.95);
      padding:.75rem;
      text-align:left;
      cursor:pointer;
      transition:transform .15s ease, border-color .15s ease, background-color .15s ease;
    }
    .du-option:hover { transform:translateY(-1px); background:white; }
    .du-option.is-selected {
      border-color:rgba(244,114,182,.42);
      background:rgba(255,241,242,.96);
      box-shadow:0 0 0 3px rgba(244,114,182,.12);
    }
    .du-option-preview {
      width:100%;
      aspect-ratio:1.2;
      border-radius:.85rem;
      background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(255,241,242,.94));
      border:1px solid rgba(244,114,182,.14);
      display:grid;
      place-items:center;
      margin-bottom:.55rem;
    }
    .du-option-preview svg { width:92%; height:92%; display:block; }
    .du-option-label { display:block; font-weight:800; }
    .du-option-note { display:block; margin-top:.18rem; font-size:.8rem; color:rgb(100 116 139); }
    .du-vote { margin-top:1rem; text-align:center; }
    .du-vote-title { margin:0 0 .7rem; font-weight:800; font-size:1.05rem; }
    .du-vote-buttons { display:flex; flex-wrap:wrap; justify-content:center; gap:.7rem; }
    .du-vote-btn {
      border:1px solid rgba(244,114,182,.26);
      border-radius:999px;
      background:white;
      color:rgb(157 23 77);
      font-weight:800;
      padding:.78rem 1rem;
      cursor:pointer;
      transition:transform .15s ease, background-color .15s ease;
    }
    .du-vote-btn:hover { transform:translateY(-1px); background:rgb(255 241 242); }
    .du-vote-message { min-height:1.6rem; margin:.85rem 0 0; font-weight:800; color:rgb(157 23 77); }
    .du-thinking {
      position:absolute;
      inset:0;
      display:grid;
      place-items:center;
      background:rgba(15,23,42,.46);
      backdrop-filter: blur(4px);
      opacity:0;
      pointer-events:none;
      transition:opacity .16s ease-out;
      z-index:3;
    }
    .du-thinking.active { opacity:1; pointer-events:auto; }
    .du-thinking-panel {
      width:min(100%, 22rem);
      border-radius:1.25rem;
      padding:1rem 1.05rem;
      background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(255,244,248,.96));
      border:1px solid rgba(244,114,182,.22);
      box-shadow:0 20px 50px rgba(15,23,42,.22);
      text-align:center;
    }
    .du-thinking-kicker {
      margin:0;
      font-size:.66rem;
      letter-spacing:.2em;
      font-weight:800;
      color:rgb(100 116 139);
    }
    .du-thinking-title {
      display:block;
      margin-top:.35rem;
      font-size:1.05rem;
      color:rgb(157 23 77);
    }
    .du-thinking-slot {
      margin:.45rem 0 0;
      color:rgb(71 85 105);
      font-weight:700;
    }
    .du-thinking-slot .dots::after {
      content:'...';
      display:inline-block;
      width:1.2em;
      overflow:hidden;
      vertical-align:bottom;
      animation: duDots 1s steps(4,end) infinite;
    }
    .du-thinking-progress {
      display:grid;
      gap:.55rem;
      margin-top:.8rem;
    }
    .du-thinking-count {
      font-size:.84rem;
      font-weight:800;
      color:rgb(236 72 153);
    }
    .du-thinking-steps {
      display:grid;
      grid-template-columns:repeat(5,minmax(0,1fr));
      gap:.38rem;
    }
    .du-thinking-step {
      height:.55rem;
      border-radius:999px;
      background:rgba(226,232,240,.95);
      border:1px solid rgba(148,163,184,.18);
    }
    .du-thinking-step.active {
      background:linear-gradient(90deg, rgba(244,114,182,.98), rgba(251,191,36,.95));
      border-color:rgba(244,114,182,.38);
      box-shadow:0 0 0 2px rgba(244,114,182,.14);
    }
    .du-thinking-step.done {
      background:linear-gradient(90deg, rgba(251,207,232,.96), rgba(253,224,71,.92));
      border-color:rgba(244,114,182,.22);
    }
    @keyframes duExpand { 0% { opacity:.5; transform:translateY(-4px); } 100% { opacity:1; transform:translateY(0); } }
    @keyframes duPop { 0% { transform:scale(.95); opacity:.7; } 65% { transform:scale(1.03); opacity:1; } 100% { transform:scale(1); opacity:1; } }
    @keyframes duRing { 0% { transform:scale(.98); } 50% { transform:scale(1.01); } 100% { transform:scale(.98); } }
    @keyframes duDots { 0% { width:0; } 100% { width:1.2em; } }
    @media (max-width: 900px) {
      .du-slotbar { grid-template-columns:repeat(2,minmax(0,1fr)); }
    }
    @media (max-width: 768px) {
      .du-top { gap:.75rem; margin-bottom:.7rem; }
      .du-kicker { font-size:.64rem; }
      .du-title { margin-top:.25rem; font-size:1.3rem; line-height:1.2; }
      .du-status { margin-bottom:.75rem; padding:.78rem .9rem; font-size:.95rem; line-height:1.45; }
      .du-meta { gap:.45rem; margin-bottom:.75rem; }
      .du-chip { padding:.58rem .65rem; border-radius:.9rem; }
      .du-chip-label { font-size:.66rem; }
      .du-chip strong { font-size:.86rem; line-height:1.35; }
      .du-actions { gap:.55rem; margin-bottom:.75rem; }
      .du-btn { padding:.72rem .92rem; }
      .du-stage { padding:.75rem; }
      .du-stage-head { margin-bottom:.7rem; }
      .du-stage-head strong { font-size:.98rem; }
