      if (preview.kind === 'ribbon') {
        return `<svg viewBox="0 0 120 90" aria-hidden="true"><circle cx="60" cy="46" r="24" fill="#fff7fb"/><path d="M60 18c-11 0-20 8-22 18 6-3 12-6 17-10 2 7 4 11 5 13 1-2 3-6 5-13 5 4 11 7 17 10-2-10-11-18-22-18Z" fill="${preview.color}"/><circle cx="60" cy="33" r="5" fill="#fff1f2"/></svg>`;
