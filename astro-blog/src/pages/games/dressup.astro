    function renderBottom(preview) {
      if (!preview) return '';
      const color = withDefault(preview.color, '#fbcfe8');
      const accent = withDefault(preview.accent, '#ffffff');
      const variant = preview.variant || 'skirt';
      if (variant === 'shorts') {
        return `<path d="M66 146h48l-6 26H96v16H84v-16H72l-6-26Z" fill="${color}"></path><path d="M74 148h32" stroke="${accent}" stroke-width="3.2" stroke-linecap="round"></path>`;
