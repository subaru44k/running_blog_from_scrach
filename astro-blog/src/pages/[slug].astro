---
import { getEntryBySlug } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getAllBlogPosts, imageForCategory } from '../lib/blog-index';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;

// Load the requested post
const post = await getEntryBySlug('blog', slug);
if (!post) {
  throw new Error(`Post not found: ${slug}`);
}
const { Content } = await post.render();
const noIndexCategories = new Set(['練習(弱)', '練習(中)', '練習(デフォルト)']);
const isSummaryPost = slug.includes('-summary-') || slug.endsWith('-summary');
const shouldNoIndex = noIndexCategories.has(post.data.category) || isSummaryPost;
const pad = (n: number) => String(n).padStart(2, '0');
const formattedDateTime = `${post.data.date.getFullYear()}-${pad(post.data.date.getMonth() + 1)}-${pad(post.data.date.getDate())} ${pad(post.data.date.getHours())}:${pad(post.data.date.getMinutes())}`;

---

<Layout noIndex={shouldNoIndex}>
  <article class="card p-0 overflow-hidden">
    <img src={imageForCategory(post.data.category)} alt={`Image for ${post.data.title}`} width="1200" height="630" class="w-full aspect-[1200/630] object-cover" loading="eager" />
    <div class="p-6 md:p-10">
      <header class="mb-6">
        <div class="flex items-center gap-3 text-xs text-gray-500 mb-2">
          <span class="badge">{post.data.category}</span>
          <time datetime={post.data.date.toISOString()}>{formattedDateTime}</time>
        </div>
        <h1 class="mb-2">{post.data.title}</h1>
      </header>
      <div class="prose max-w-none dark:prose-invert"><Content /></div>
    </div>
  </article>
</Layout>
